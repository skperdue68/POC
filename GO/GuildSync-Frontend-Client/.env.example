# Optional override for the Elder Scrolls Online SavedVariables directory.
# Leave blank to let GuildSync try the normal default location for your OS/user.
#
# Windows example:
# SAVED_VARS_DIR=C:\Users\YourUserName\Documents\Elder Scrolls Online\live\SavedVariables
#
# macOS example:
# SAVED_VARS_DIR=/Users/YourUserName/Documents/Elder Scrolls Online/live/SavedVariables
#
# Linux / Steam Deck / Proton example:
# SAVED_VARS_DIR=/home/deck/.steam/steam/steamapps/compatdata/<ESO_APP_ID>/pfx/drive_c/users/steamuser/Documents/Elder Scrolls Online/live/SavedVariables
SAVED_VARS_DIR=

# Optional override for the GuildSync Banking saved variables file name.
# Leave blank to watch GuildSyncBanking.lua.
SAVED_VARS_BANKING_FILE_NAME=

# Optional override for the GuildSync Roster saved variables file name.
# Leave blank to watch GuildSyncRoster.lua.
SAVED_VARS_ROSTER_FILE_NAME=

# Optional override for the Lua top-level banking SavedVariables table name.
# Leave blank to use GuildSyncBanking.
SAVED_VARS_BANKING_TABLE_NAME=
