DISCORD_TOKEN=YOUR_DISCORD_TOKEN
DISCORD_CLIENT_ID=YOUR_CLIENT ID
DISCORD_GUILD_ID=YOUR_GUILD_ID

GUILDSYNC_SOCKET_URL=http://localhost:3001
GUILDSYNC_BOT_KEY=KEY MUST BE SAME IN GUILDLSYNC ALSO

# Optional. If true, the bot checks the GuildSync backend on startup and runs a one-time
# historical message scan only if the backend says it has never completed before.
GUILDSYNC_HISTORICAL_SCAN_ON_STARTUP=false

# Optional. Maximum historical messages to check per text/announcement channel.
GUILDSYNC_HISTORICAL_SCAN_MESSAGE_LIMIT_PER_CHANNEL=1000

ESO_GUILD_APPLICATIONS=Server_ID:Thread_ID