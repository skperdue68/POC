# Local development server bind settings.
HOST=0.0.0.0
PORT=3001

# Public access notes:
# Nginx Proxy Manager should route https://guildsync.perdues.me to this backend host/port.
# Enable WebSocket support in Nginx Proxy Manager for Socket.IO.
# Desktop OAuth redirect should remain local because the Wails client listens on 127.0.0.1.

#DATA_DIR=Path to Database filles

# Discord OAuth application settings.
DISCORD_CLIENT_ID=DISCORD_CLIENT_ID
DISCORD_CLIENT_SECRET=DISCORD_CLIENT_SECRET
DISCORD_REDIRECT_URI=http://127.0.0.1:53682/callback
DISCORD_WEB_REDIRECT_URI=https://guildsync.perdues.me/api/auth/discord/web-callback
GUILDSYNC_WEB_PUBLIC_URL=https://guildsync.perdues.me

# Long random secret used to sign GuildSync JWT session tokens.
# For production, generate a long random value and keep it private.
GUILDSYNC_JWT_SECRET=REPLACE_THIS_WITH_A_LONG_RANDOM_SECRET
GUILDSYNC_TOKEN_TTL_SECONDS=86400

#Must be the same in the GuildSync NodeJS Bot as well
GUILDSYNC_BOT_SOCKET_KEY=GUILDSYNC_BOT_SOCKET_KEY

#Current Client Version, update if you want users prompted to update their client
GUILDSYNC_CLIENT_VERSION=1.0.3


MARIADB_HOST=127.0.0.1
MARIADB_PORT=3306
MARIADB_USER=root
MARIADB_PASSWORD=Sc0ttsd@13
MARIADB_DATABASE=guildsync
MARIADB_CONNECTION_LIMIT=10

# ESO guild id allowed for GuildSyncApplications.lua records.
GUILDSYNC_APPLICATIONS_GUILD_ID=761817
# Deposit mail templates rendered by the backend when mail is checked out.
# Supported placeholders: {recipient}, {account_name}, {event_id}, {ticket_type}, {ticket_type_raw}, {amount}, {deposit_amount}, {ticket_gold_cost}, {gold_cost}, {raw_amount}, {raw_deposit_amount}, {ticket_quantity}, {tickets}, {purchase_date}, {raffle_datetime_eastern}, {raffle_datetime}, {event_datetime}, {event_timestamp}, {mail_request_id}, {mail_batch_id}, {transaction_type}, {data_source}, {note}, {note_block}
# {amount}/{deposit_amount}/{ticket_gold_cost}/{gold_cost} are the actual ESO deposit/ticket cost, including any +1/+3 raffle marker. Raffle summary totals remove the marker only for display/calculation.
GUILDSYNC_DEPOSIT_MAIL_SUBJECT_TEMPLATE=Alphabet Mafia raffle ticket purchase receipt
GUILDSYNC_DEPOSIT_MAIL_BODY_TEMPLATE="Hi {recipient},\n\nThank you for supporting Alphabet Mafia!\n\nTicket Type: {ticket_type}\nTickets Purchased: {ticket_quantity}\nPurchase Date: {purchase_date}\nGold Cost: {ticket_gold_cost} gold\n{note_block}\nRaffle Date: {raffle_datetime_eastern}\n\n-- Alphabet Mafia"

